# ============================================================
# Synapse Server — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# -----------------------------------------------------------
# Google Gemini API Key (Free tier available at ai.google.dev)
# -----------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------
# Server Port (Render will inject its own PORT automatically)
# -----------------------------------------------------------
PORT=5001

# -----------------------------------------------------------
# Allowed CORS Origins — comma-separated list
# Example: http://localhost:5173,https://synapse-client.vercel.app
# -----------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173
